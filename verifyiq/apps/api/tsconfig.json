{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "multer"],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "src/main.ts",
    "src/app.module.ts",
    "src/verify/**/*.ts",
    "src/ml-client/**/*.ts",
    "src/fraud/**/*.ts",
    "../../libs/types/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
